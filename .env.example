APP_NAME=app1
HOST_PORT=8080
PHP_IMAGE_VERSION=3.0
UID=1000
GID=1000
GIT_NAME="Your Name"
GIT_EMAIL="you@example.com"

# everything below will only be use if you create docker-compose.override.yml using docker-compose.override.example.yml file
# HTTPS_HOST_PORT=8443
MYSQL_NETWORK_NAME=mysql_network
MYSQL_DATABASE=$APP_NAME
RMQ_NETWORK_NAME=rabbitmq_network


DATABASE_URL="mysql://$MYSQL_USER:$MYSQL_PASSWORD@mysql8:3306/$MYSQL_DATABASE?serverVersion=8.4.3"
MESSENGER_TRANSPORT_DSN="amqp://admin:password@rabbitmq:5672"
